PORT=8080
ENVIRONMENT=production
MONGO_URI=mongodb://root:dev2@mongodb:27017/dev2knowledge?authSource=admin
MONGO_DATABASE=dev2knowledge
NATS_URL=nats://nats:4223

# LLM — used as fallback if NATS to dev2-llm-service is unavailable
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Service URLs
KNOWLEDGE_SVC_URL=http://dev2-knowledge:8080
TICKETS_SVC_URL=http://dev2-tickets:8080
PT_SVC_URL=https://app.project-tracker.ai/api

# Service-to-service / tooling API key (optional but recommended).
# When set, requests carrying "X-API-Key: <this value>" bypass JWT auth.
# Also used by THIS service when calling sibling services.
# Generate with: openssl rand -hex 32   (use the SAME value across all services)
SERVICE_API_KEY=

# Authentik JWT verification. Both values are required for browser/JWT routes.
AUTHENTIK_ISSUER=https://auth.dev2.solutions/application/o/dev2-solutions/
AUTHENTIK_AUDIENCE=dev2-solutions

# REST/SSE CORS and WebSocket origins are separate exact allowlists. Production
# defaults never include localhost; add localhost explicitly for development.
CHAT_ALLOWED_ORIGINS=https://dev2.solutions
CHAT_SOCKET_ALLOWED_ORIGINS=https://dev2.solutions
CHAT_SOCKET_SEND_QUEUE=128
CHAT_SOCKET_READ_LIMIT_BYTES=65536
CHAT_SOCKET_PING_INTERVAL=25s
CHAT_SOCKET_IDLE_TIMEOUT=60s
CHAT_SOCKET_MAX_LIFETIME=30m
CHAT_SOCKET_DEVELOPER_MAX_LIFETIME=5m
CHAT_SOCKET_SERVICE_MAX_LIFETIME=5m
CHAT_SOCKET_TICKET_RATE_PER_MINUTE=10
CHAT_SOCKET_MAX_OUTSTANDING_TICKETS=3
CHAT_SOCKET_CONNECTIONS_GLOBAL=500
CHAT_SOCKET_CONNECTIONS_PER_COMPANY=50
CHAT_SOCKET_CONNECTIONS_PER_USER=3
CHAT_SOCKET_CONNECTIONS_PER_IP=20
CHAT_SOCKET_CONNECTION_LEASE_TTL=75s
CHAT_SOCKET_GENERATIONS_PER_COMPANY=20
CHAT_SOCKET_GENERATIONS_PER_USER=2
CHAT_SOCKET_GENERATION_LEASE_TTL=3m
CHAT_SOCKET_MESSAGES_PER_MINUTE=60
CHAT_SOCKET_MESSAGE_BURST=20
